<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="mod/memory3d/db" VERSION="2026051800" COMMENT="XMLDB for mod_memory3d"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="../../../lib/xmldb/xmldb.xsd"
>
  <TABLES>
    <TABLE NAME="memory3d" COMMENT="Instances of memory3d activity">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="course" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="name" TYPE="char" LENGTH="255" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="intro" TYPE="text" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="introformat" TYPE="int" LENGTH="4" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="sourcetext" TYPE="text" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="sourceorigin" TYPE="char" LENGTH="20" NOTNULL="true" DEFAULT="pdftext" SEQUENCE="false"/>
        <FIELD NAME="sourcecmid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="sourceqcategoryid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="qbankuseai" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="qbankmixmode" TYPE="char" LENGTH="10" NOTNULL="true" DEFAULT="exact" SEQUENCE="false"/>
        <FIELD NAME="qbankaiextra" TYPE="int" LENGTH="2" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="qbankaipercent" TYPE="int" LENGTH="3" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="requestedpairs" TYPE="int" LENGTH="2" NOTNULL="true" DEFAULT="6" SEQUENCE="false"/>
        <FIELD NAME="gamemode" TYPE="char" LENGTH="20" NOTNULL="true" DEFAULT="memory" SEQUENCE="false"/>
        <FIELD NAME="difficulty" TYPE="char" LENGTH="20" NOTNULL="true" DEFAULT="medium" SEQUENCE="false"/>
        <FIELD NAME="gradepolicy" TYPE="char" LENGTH="20" NOTNULL="true" DEFAULT="best" SEQUENCE="false"/>
        <FIELD NAME="pairscount" TYPE="int" LENGTH="4" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="pairsjson" TYPE="text" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="lastaierror" TYPE="text" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="aigeneratedat" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="course" UNIQUE="false" FIELDS="course"/>
      </INDEXES>
    </TABLE>
    <TABLE NAME="memory3d_attempts" COMMENT="Attempts and grades per user for memory3d activity">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="memory3did" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="gamemode" TYPE="char" LENGTH="20" NOTNULL="true" DEFAULT="memory" SEQUENCE="false"/>
        <FIELD NAME="rawscore" TYPE="number" LENGTH="10" DECIMALS="2" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="maxscore" TYPE="number" LENGTH="10" DECIMALS="2" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="finalgrade" TYPE="number" LENGTH="10" DECIMALS="5" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="memory3did_idx" UNIQUE="false" FIELDS="memory3did"/>
        <INDEX NAME="userid_idx" UNIQUE="false" FIELDS="userid"/>
        <INDEX NAME="mem_user_idx" UNIQUE="false" FIELDS="memory3did, userid"/>
      </INDEXES>
    </TABLE>
  </TABLES>
</XMLDB>
